{
    "name": "rbr/laravel-api-docs",
    "description": "A self-analyzing tool that scans a Laravel project's routes, controllers, and FormRequests to generate browsable API documentation.",
    "keywords": ["laravel", "api", "documentation", "generator", "rbr","raju","rashedul"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Rashedul Bari Raju",
            "email": "rbraju3m@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "symfony/process": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Rbr\\LaravelApiDocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rbr\\LaravelApiDocs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rbr\\LaravelApiDocs\\ApiDocServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
